#!/usr/bin/env bash
# =============================================================================
# tdir - Smart Tagged Directory Creator & Searcher (macOS)
# Fixed & Improved version - May 2025
#
# USAGE:
#   ./tdir <folder-name> [tag1 tag2 ...]          # create + tag
#   ./tdir create <folder-name> [tag1 tag2 ...]
#   ./tdir search <tag1> [tag2 ...]
#   ./tdir list-tags [folder-path]
#   ./tdir help
# =============================================================================

set -euo pipefail

# ===================== CONFIGURATION =====================
TAG_FILE=".tags"                    # Hidden file that stores tags (one per line)
SEARCH_DEPTH=5                      # How deep to search (increase if you have deep folders)

# ===================== HELPER FUNCTIONS =====================

# Print usage and exit
usage() {
    cat <<EOF
Usage:
  tdir <folder-name> [tag1 tag2 ...]     # Create folder and add tags
  tdir create <folder-name> [tag1 tag2 ...]
  tdir search <tag1> [tag2 ...]          # Find folders by tags
  tdir list-tags [path]                  # Show tags of a folder (default: current)
  tdir help
EOF
    exit 1
}

# Save tags to .tags file inside the folder (one tag per line, sorted, unique)
save_tags() {
    local dir="$1"
    shift
    local tags=("$@")

    if [[ ${#tags[@]} -eq 0 ]]; then
        return 0
    fi

    # Write tags (one per line) → sorted and deduplicated
    printf "%s\n" "${tags[@]}" | sort -u > "${dir}/${TAG_FILE}"
    echo "✓ Tags saved: ${tags[*]}" >&2
}

# Read tags from a folder's .tags file
get_tags() {
    local dir="$1"
    if [[ -f "${dir}/${TAG_FILE}" ]]; then
        cat "${dir}/${TAG_FILE}"
    else
        echo ""   # no tags
    fi
}

# ===================== MAIN LOGIC =====================
main() {
    if [[ $# -eq 0 ]]; then
        usage
    fi

    local cmd="${1:-}"
    shift || true   # safely remove first argument

    case "$cmd" in
        create|"" )
            # ------------------- CREATE MODE -------------------
            if [[ $# -eq 0 ]]; then
                usage
            fi

            local folder_name="$1"
            shift

            # Create the directory (and parents if needed)
            mkdir -p "$folder_name"
            echo "✓ Directory created: $(pwd)/$folder_name"

            # Save tags if any were given
            if [[ $# -gt 0 ]]; then
                save_tags "$folder_name" "$@"
            fi
            ;;

        search )
            # ------------------- SEARCH MODE -------------------
            if [[ $# -eq 0 ]]; then
                echo "Error: Provide at least one tag to search" >&2
                usage
            fi

            echo "🔎 Searching for folders matching tags: $*" >&2
            echo "────────────────────────────────────────"

            # Find all .tags files, then check if they contain any of the requested tags
            find . -maxdepth "$SEARCH_DEPTH" -name "$TAG_FILE" -type f 2>/dev/null | while read -r tagfile; do
                local folder="${tagfile%/*}"          # remove /filename → get folder path
                local matched=false

                for tag in "$@"; do
                    if grep -qixF "$tag" "$tagfile"; then
                        matched=true
                        break
                    fi
                done

                if [[ "$matched" == true ]]; then
                    local tags=$(get_tags "$folder" | tr '\n' ' ' | xargs)
                    printf "📁 %s   [ %s ]\n" "${folder#./}" "${tags:-no tags}"
                fi
            done
            ;;

        list-tags )
            # ------------------- LIST TAGS MODE -------------------
            local target="${1:-.}"          # default to current directory if no argument

            if [[ ! -d "$target" ]]; then
                echo "Error: '$target' is not a directory" >&2
                exit 1
            fi

            local tags=$(get_tags "$target")
            if [[ -n "$tags" ]]; then
                echo "Tags for '$(realpath "$target")':"
                echo "$tags" | sed 's/^/   • /'
            else
                echo "No tags found for '$(realpath "$target")'."
            fi
            ;;

        help|--help|-h )
            usage
            ;;

        * )
            # ------------------- CONVENIENCE MODE -------------------
            # First argument was not a command → treat it as folder name
            local folder_name="$cmd"
            shift || true

            mkdir -p "$folder_name"
            echo "✓ Directory created: $(pwd)/$folder_name"

            if [[ $# -gt 0 ]]; then
                save_tags "$folder_name" "$@"
            fi
            ;;
    esac
}

# ===================== EXECUTE =====================
main "$@"