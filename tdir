#!/usr/bin/env bash

set -euo pipefail   # Strict mode: exit on error, undefined vars, pipe failures

# CONFIGURATION 
TAG_FILE=".tags"          # File that stores one tag per line
SEARCH_DEPTH=6            # How deep to search recursively

# HELPER FUNCTIONS 

# 1. Show usage when user does something wrong
usage() {
    cat <<EOF
Usage:
  tdir <folder-name> [tag1 tag2 tag3 ...]          # Create folder + tags
  tdir create <folder-name> [tag1 tag2 ...]
  tdir search <tag1> [tag2 ...]                    # Search folders by tags
  tdir list-tags [path]                            # Show tags of a folder
  tdir help
EOF
    exit 1
}

# 2. Save tags to .tags file inside the folder
# Input:  $1 = directory path, $2... = list of tags
# Output: Creates/updates .tags file with unique sorted tags (one per line)
# Prints confirmation to stdout
save_tags() {
    local dir="$1"          # First argument = target directory
    shift                   # Remove first argument so "$@" now contains only tags
    local tags=("$@")       # Store remaining arguments as array

    if [[ ${#tags[@]} -eq 0 ]]; then
        return 0            # No tags provided → do nothing
    fi

    # Write tags (one per line), remove duplicates, sort them
    printf "%s\n" "${tags[@]}" | sort -u > "${dir}/${TAG_FILE}"
    
    # Inform user what was saved
    echo "✓ Tags saved: ${tags[*]}"
}

# 3. Read tags from a folder's .tags file
# Input:  $1 = directory path
# Output: Prints tags (one per line) or nothing if file doesn't exist
get_tags() {
    local dir="$1"
    if [[ -f "${dir}/${TAG_FILE}" ]]; then
        cat "${dir}/${TAG_FILE}"
    fi
}

# MAIN LOGIC

main() {
    # If no arguments at all → show usage
    if [[ $# -eq 0 ]]; then
        usage
    fi

    local cmd="$1"          # First word user typed (command or folder name)
    shift                   # Remove first argument so "$@" now contains the rest

    case "$cmd" in
        # CREATE MODE
        create)
            if [[ $# -eq 0 ]]; then usage; fi
            
            local folder_name="$1"   # Next argument = name of folder to create
            shift                    # Remaining arguments = tags

            # Create the directory
            mkdir -p "$folder_name"
            echo "✓ Directory created: $(realpath "$folder_name")"

            # Save any tags that were provided
            save_tags "$folder_name" "$@"
            ;;

        # SEARCH MODE 
        search)
            if [[ $# -eq 0 ]]; then
                echo "Error: Provide at least one tag to search" >&2
                usage
            fi

            echo "Tags: $*"
            # Find every .tags file within SEARCH_DEPTH
            # For each .tags file, check if ANY of the search tags exist inside it
            find . -maxdepth "$SEARCH_DEPTH" -name "$TAG_FILE" -type f 2>/dev/null | while read -r tagfile; do
                local folder="${tagfile%/*}"          # Get folder path (remove /${TAG_FILE})
                local matched=false

                # Check each search tag against the .tags file
                for tag in "$@"; do
                    if grep -qixF "$tag" "$tagfile"; then
                        matched=true
                        break
                    fi
                done

                # If at least one tag matched, print the folder
                if [[ "$matched" == true ]]; then
                    local tags=$(get_tags "$folder" | tr '\n' ' ' | xargs)
                    printf "📁 %-40s [ %s ]\n" "${folder#./}" "${tags:-no tags}"
                fi
            done
            ;;

        # LIST TAGS MODE
        list-tags)
            local target="${1:-}"          # Default to current directory if no path given
            if [[ ! -d "$target" ]]; then
                echo "Error: '$target' is not a directory" >&2
                exit 1
            fi
            local tags=$(get_tags "$target")
            if [[ -n "$tags" ]]; then
                echo "Tags in '$(realpath "$target")':"
                echo "$tags"
            else
                echo "No tags found for '$(realpath "$target")'."
            fi
            ;;

        help|--help|-h)
            usage
            ;;

        # ------------------- CONVENIENCE MODE (default) -------------------
        # User typed: tdir my-folder tag1 tag2 ...
        *)
            local folder_name="$cmd"   # First argument becomes folder name
            # All remaining arguments become tags (no extra shift)
            mkdir -p "$folder_name"
            echo "✓ Directory created: $(realpath "$folder_name")"
            save_tags "$folder_name" "$@"
            ;;
    esac
}

# ===================== START EXECUTION =====================
main "$@"